generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id       String    @id @db.Uuid
  comments Comment[]
}

model Member {
  id                   String               @id @default(uuid()) @db.Uuid
  private_id           String?
  name                 String
  normalized_name      String?
  avatar_url           String?
  gender               String?
  birthDate            String?
  deathDate            String?
  created_at           DateTime             @default(now())
  anniversaries        Anniversary[]
  comments             Comment[]
  child_relationships  MemberRelationship[] @relation("RelChild")
  parent_relationships MemberRelationship[] @relation("RelParent")
  profile              Profile?
  from_relationships   Relationship[]       @relation("FromMember")
  to_relationships     Relationship[]       @relation("ToMember")
  user_metadata        UserMetadata?

  @@map("members")
}

model Profile {
  id         String   @id @default(uuid()) @db.Uuid
  member_id  String   @unique @db.Uuid
  fullName   String
  generation Int?
  biography  String?
  occupation String?
  address    String?
  notes      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  member     Member   @relation(fields: [member_id], references: [id])

  @@map("profiles")
}

model Relationship {
  id             String           @id @default(uuid()) @db.Uuid
  from_member_id String           @db.Uuid
  to_member_id   String           @db.Uuid
  type           RelationshipType
  created_at     DateTime         @default(now())
  from_member    Member           @relation("FromMember", fields: [from_member_id], references: [id])
  to_member      Member           @relation("ToMember", fields: [to_member_id], references: [id])

  @@map("relationships")
}

model MemberRelationship {
  id         String                 @id @default(uuid()) @db.Uuid
  parent_id  String                 @db.Uuid
  child_id   String                 @db.Uuid
  type       RelationshipNatureType
  note       String?
  created_at DateTime               @default(now())
  child      Member                 @relation("RelChild", fields: [child_id], references: [id])
  parent     Member                 @relation("RelParent", fields: [parent_id], references: [id])

  @@map("member_relationships")
}

model Tree {
  id          String   @id @default(uuid()) @db.Uuid
  owner_id    String   @db.Uuid
  created_at  DateTime @default(now())
  description String?
  image       String?
  title       String?
  show        Boolean  @default(false)

  @@map("trees")
}

model Comment {
  id               String   @id @default(uuid()) @db.Uuid
  content          String
  author_id        String   @db.Uuid
  target_member_id String?  @db.Uuid
  created_at       DateTime @default(now())
  author           User     @relation(fields: [author_id], references: [id])
  target_member    Member?  @relation(fields: [target_member_id], references: [id])

  @@map("comments")
}

model Media {
  id          String   @id @default(uuid()) @db.Uuid
  file_path   String
  uploader_id String   @db.Uuid
  created_at  DateTime @default(now())

  @@map("media")
}

model UserMetadata {
  id                String   @id @default(uuid()) @db.Uuid
  user_id           String   @unique @db.Uuid
  profile_member_id String?  @unique @db.Uuid
  roles             String[]
  profile_member    Member?  @relation(fields: [profile_member_id], references: [id])

  @@map("user_metadata")
}

model Cemetery {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  latitude    Float
  longitude   Float
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("cemeteries")
}

model Anniversary {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  date        DateTime
  description String?
  member_id   String?  @db.Uuid
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  member      Member?  @relation(fields: [member_id], references: [id])

  @@map("anniversaries")
}

model Event {
  id          String    @id @default(uuid()) @db.Uuid
  title       String
  description String?
  images      String[]
  highlight   Boolean   @default(false)
  date        DateTime?
  location    String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  @@map("events")
}

enum RelationshipType {
  PARENT
  CHILD
  SPOUSE
}

enum RelationshipNatureType {
  BIOLOGICAL
  ADOPTED
  SPOUSE
}
